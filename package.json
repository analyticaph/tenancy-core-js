{
  "name": "@analyticaph/tenancy-core-js",
  "version": "0.1.0",
  "description": "Shared React/TS utilities for multi-tenant school platform apps",
  "main": "src/index.ts",
  "module": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "require": "./src/index.ts"
    },
    "./react": {
      "types": "./src/react.ts",
      "import": "./src/react.ts",
      "require": "./src/react.ts"
    },
    "./auth": {
      "types": "./src/auth/tokenStorage.ts",
      "import": "./src/auth/tokenStorage.ts",
      "require": "./src/auth/tokenStorage.ts"
    },
    "./oauth": {
      "types": "./src/oauth/redirectFlow.ts",
      "import": "./src/oauth/redirectFlow.ts",
      "require": "./src/oauth/redirectFlow.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "axios": "^1.0.0",
    "react": "^18.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  }
}
